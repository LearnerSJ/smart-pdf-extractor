# PDF Ingestion Layer - Environment Variables
# Copy this file to .env and fill in the values.

# ─── AWS / Bedrock ────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_SESSION_TOKEN=your-session-token-if-using-temporary-credentials
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
VLM_CONFIDENCE_THRESHOLD=0.80

# ─── Triangulation thresholds ─────────────────────────────────────────────────
TRIANGULATION_SOFT_FLAG_THRESHOLD=0.10
TRIANGULATION_HARD_FLAG_THRESHOLD=0.40

# ─── Services ─────────────────────────────────────────────────────────────────
PADDLEOCR_ENDPOINT=http://paddleocr:8080
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pdf_ingestion

# ─── Extraction ───────────────────────────────────────────────────────────────
DIGITAL_PAGE_THRESHOLD=0.80
VLM_VERIFIER_FUZZY_THRESHOLD=0.85

# ─── Chunked VLM Extraction ──────────────────────────────────────────────────
VLM_MAX_TOKENS_PER_JOB=500000
VLM_BUDGET_EXCEEDED_ACTION=flag
VLM_WINDOW_SIZE=12
VLM_WINDOW_OVERLAP=3
VLM_MAX_CONCURRENT_WINDOWS=10

# ─── Auto-Schema Discovery ───────────────────────────────────────────────────
DISCOVERY_SAMPLE_PAGES=5
DISCOVERY_MAX_CONTEXT_RATIO=0.80
DISCOVERY_CACHE_ENABLED=true

# ─── File limits ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=100

# ─── Admin Dashboard - JWT ────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=8

# ─── Admin Dashboard - Token cost rates (per 1k tokens) ──────────────────────
TOKEN_COST_PER_1K_INPUT=0.003
TOKEN_COST_PER_1K_OUTPUT=0.015

# ─── Admin Dashboard - Alert engine ──────────────────────────────────────────
ALERT_EVALUATION_INTERVAL_SECONDS=60

# ─── Admin Dashboard - SMTP (for email notifications) ────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=alerts@pdf-ingestion.local
