# PDF Ingestion Layer - Environment Variables
# Copy this file to .env and fill in the values.

# AWS / Bedrock
AWS_REGION=eu-west-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
VLM_CONFIDENCE_THRESHOLD=0.80

# Triangulation thresholds
TRIANGULATION_SOFT_FLAG_THRESHOLD=0.10
TRIANGULATION_HARD_FLAG_THRESHOLD=0.40

# Services
PADDLEOCR_ENDPOINT=http://paddleocr:8080
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pdf_ingestion

# Extraction
DIGITAL_PAGE_THRESHOLD=0.80
VLM_VERIFIER_FUZZY_THRESHOLD=0.85

# File limits
MAX_FILE_SIZE_MB=50
